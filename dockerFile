# Stage 1: Builder
FROM python:3.13-slim AS builder

# Set working directory
WORKDIR /app

# Install uv for fast dependency resolution and installation
RUN pip install --no-cache-dir uv

# Enable bytecode compilation and disable uv Python downloads
ENV UV_COMPILE_BYTECODE=1 \
    UV_PYTHON_DOWNLOADS=never

# Copy only the dependency specification files first
COPY pyproject.toml uv.lock ./

# Install dependencies into /app/.venv
# Using --frozen ensures uv.lock is used without updating it
# Using --no-dev skips installing development dependencies
# Using --no-install-project skips installing the current project itself yet
RUN uv sync --frozen --no-dev --no-install-project --python 3.13

# Copy the rest of the application code
COPY . .

# Run uv sync again to install the project if necessary, 
# although copying source files to final image is often enough.
RUN uv sync --frozen --no-dev --python 3.13

# Stage 2: Final
FROM python:3.13-slim

WORKDIR /app

# Copy the entire /app directory from the builder
COPY --from=builder /app /app

# Ensure the virtual environment's binaries are on the PATH
ENV PATH="/app/.venv/bin:$PATH" \
	PYTHONUNBUFFERED=1 \
	PYTHONDONTWRITEBYTECODE=1

EXPOSE 8000

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]